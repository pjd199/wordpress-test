{
  "name": "WordPress Development Codespace",
  "postCreateCommand": "sudo curl -L -o /usr/local/bin/wpc https://raw.githubusercontent.com/pjd199/wordpress-test/6.9.4+4/wpc.sh && sudo chmod +x /usr/local/bin/wpc",
  "postStartCommand": "wpc start",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": { 
        "label": "WordPress", 
        "onAutoForward": "openBrowserOnce" }
  }
}
